//JS

function sum(array) {
    let total = 0;

    for (let i = 0; i < array.length; i++) {
        if (!isNaN(array[i])) {
            total += Number(array[i]);
        }
    }

    return total;
}

console.log(sum([1,2,3]));
console.log(sum([100,-200,3]));
console.log(sum([1,2,"a",3]));
