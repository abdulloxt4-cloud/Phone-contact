//JS

function lcm_two_numbers(a, b) {

    let max = a > b ? a : b;

    while (true) {

        if (max % a == 0 && max % b == 0) {
            return max;
        }

        max++;
    }

}


console.log(lcm_two_numbers(3,15));

console.log(lcm_two_numbers(10,15));
