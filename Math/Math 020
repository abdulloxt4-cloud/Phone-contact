//JS

function factorial(number) {
    let result = 1;

    for (let i = 1; i <= number; i++) {
        result *= i;
    }

    return result;
}

function binomial(n, k) {
    return factorial(n) / (factorial(k) * factorial(n - k));
}

console.log(binomial(8, 3));
console.log(binomial(10, 2));
