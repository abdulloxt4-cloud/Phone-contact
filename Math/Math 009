//JS

function gcd_more_than_two_numbers(numbers) {

    let gcd = 1;

    for (let i = 1; i <= Math.min(...numbers); i++) {

        if (numbers.every(num => num % i == 0)) {
            gcd = i;
        }

    }

    return gcd;
}


console.log(gcd_more_than_two_numbers([3,15,27]));

console.log(gcd_more_than_two_numbers([5,10,15,25]));
