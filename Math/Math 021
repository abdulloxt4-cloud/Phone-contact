//JS

function integer_to_roman(number) {

    const roman = [
        ["M",1000],
        ["CM",900],
        ["D",500],
        ["CD",400],
        ["C",100],
        ["XC",90],
        ["L",50],
        ["XL",40],
        ["X",10],
        ["IX",9],
        ["V",5],
        ["IV",4],
        ["I",1]
    ];

    let result = "";

    for(let i = 0; i < roman.length; i++){

        while(number >= roman[i][1]){
            result += roman[i][0];
            number -= roman[i][1];
        }

    }

    return result;
}

console.log(integer_to_roman(25));
console.log(integer_to_roman(99));
console.log(integer_to_roman(2024));
