<!DOCTYPE html>
<html>
<head>
    <title>Fetch API</title>
</head>
<body>

<h2>Users</h2>

<div id="result"></div>

<script src="main.js"></script>

</body>
</html>

//JS 
// getElementById() - HTML elementini oladi
let users = document.getElementById("users");

// fetch() - API dan ma'lumot oladi
fetch("https://jsonplaceholder.typicode.com/users")

// then() - ma'lumot kelgandan keyin ishlaydi
.then(function(response){

    // response.json() - JSON ma'lumotni JS formatiga o'tkazadi
    return response.json();

})

// then() - olingan ma'lumot bilan ishlaydi
.then(function(data){

    // forEach() - har bir elementni aylanadi
    data.forEach(function(user){

        // innerHTML - HTML ichiga yozadi
        users.innerHTML += "<p>" + user.name + "</p>";

    });

})

// catch() - xatoni ushlaydi
.catch(function(){

    // innerHTML - xato xabarini chiqaradi
    users.innerHTML = "Error loading data.";

});
