//8 // Happy Number: raqamlar kvadratini qo'shib, 1 chiqishini tekshiradi
function isHappy(num) {

    while (num !== 1 && num !== 4) {

        let sum = 0;

        while (num > 0) {

            let digit = num % 10;

            sum = sum + (digit ** 2);

            num = Math.floor(num / 10);
        }

        num = sum;
    }

    return num === 1;
}


let son = 1;
let count = 0;

while (count < 5) {

    if (isHappy(son)) {
        console.log(son);
        count++;
    }

    son++;
}



