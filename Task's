// 11 GCD (Greatest Common Divisor) — EKUB (Eng katta umumiy bo'luvchi)
//% → qoldiqni topish === 0 → qoldiq 0 ga tengmi (qoldiqsiz bo'linadimi)
let a = 20;
let b = 30;

let ekub = 1;

for (let i = 1; i <= a && i <= b; i++) {

    if (a % i === 0 && b % i === 0) {
        ekub = i;
    }

}

console.log(ekub);


