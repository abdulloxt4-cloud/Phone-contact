  //JS

  class Vehicle {
    constructor(make, model, year) {
        this.make = make;
        this.model = model;
        this.year = year;
    }

    displayDetails() {
        console.log(`Vehicle Details:\nMake: ${this.make}\nModel: ${this.model}\nYear: ${this.year}\n`);
    }
}

class Car extends Vehicle {
    constructor(make, model, year, doors) {
        super(make, model, year);
        this.doors = doors;
    }

    displayDetails() {
        console.log(`Car Details:\nMake: ${this.make}\nModel: ${this.model}\nYear: ${this.year}\nDoors: ${this.doors}`);
    }
}

let myVehicle = new Vehicle("Ford", "F-150", 2020);
myVehicle.displayDetails();

let myCar = new Car("Honda", "Accord", 2023, 4);
myCar.displayDetails();
