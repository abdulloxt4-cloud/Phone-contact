<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <title>2-mashq</title>
</head>
<body>

    <button onclick="start()">Click</button>

    <h2 id="text"></h2>

    <script src="main.js"></script>

</body>
</html>

//JS
function delay() {
    return new Promise(function (resolve) {
        setTimeout(function () {
            resolve("Hello");
        }, 2000);
    });
}

function start() {
    delay().then(function (result) {
        document.getElementById("text").textContent = result;
    });
}
